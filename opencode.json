{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "default_agent": "forensic-examiner",
  "disabled_providers": ["gemini", "google", "ollama"],
  "instructions": [
    "AGENTS.md",
    ".github/agents/*.agent.md",
    "docs/limitations.md",
    "docs/tooling-matrix.md",
    "docs/peer-review-process.md",
    "docs/privacy-and-redaction.md"
  ],
  "agent": {
    "forensic-examiner": {
      "description": "User-facing forensic examiner for scoped host, filesystem, and image investigations with Markdown reporting.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-examiner.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "forensic-toolsmith": "allow",
          "forensic-peer-reviewer": "allow",
          "forensic-maintainer": "allow"
        },
        "bash": {
          "*": "ask",
          "Get-Date*": "allow",
          "Get-TimeZone*": "allow",
          "hostname*": "allow",
          "whoami*": "allow",
          "quser*": "allow",
          "Get-CimInstance Win32_*": "allow",
          "Get-ComputerInfo*": "allow",
          "Get-Process*": "allow",
          "Get-WinEvent*": "allow",
          "wevtutil *": "allow",
          "Test-Path *": "allow"
        },
        "edit": "ask",
        "write": "ask"
      }
    },
    "forensic-toolsmith": {
      "description": "Internal tooling specialist for selecting, staging, and verifying the smallest defensible forensic toolchain.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-toolsmith.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "forensic-maintainer": "allow"
        },
        "bash": {
          "*": "ask",
          "Get-Date*": "allow",
          "Get-TimeZone*": "allow",
          "hostname*": "allow",
          "whoami*": "allow",
          "quser*": "allow",
          "Get-Command *": "allow",
          "Get-CimInstance Win32_*": "allow",
          "Get-ComputerInfo*": "allow",
          "Get-Process*": "allow",
          "Get-WinEvent*": "allow",
          "wevtutil *": "allow",
          "Test-Path *": "allow"
        },
        "edit": "ask",
        "write": "ask"
      }
    },
    "forensic-peer-reviewer": {
      "description": "Internal second-reader for challenging forensic reports, inference strength, corroboration, and release readiness.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-peer-reviewer.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": "deny",
        "bash": "deny",
        "edit": "deny",
        "write": "deny"
      }
    },
    "forensic-maintainer": {
      "description": "Internal maintainer for narrow, justified workflow updates after real investigations or tooling friction.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-maintainer.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": "deny",
        "bash": "ask",
        "edit": "ask",
        "write": "ask"
      }
    }
  }
}
