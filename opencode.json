{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.5",
  "small_model": "github-copilot/gpt-5.5",
  "default_agent": "forensic-examiner",
  "disabled_providers": ["gemini", "google"],
  "provider": {
    "llamacpp-local": {
      "options": {
        "timeout": 3600000,
        "chunkTimeout": 3600000
      },
      "models": {
        "gemma-heretic-bf16": {
          "options": {
            "reasoningEffort": "none",
            "textVerbosity": "low",
            "temperature": 0
          },
          "limit": {
            "context": 16384,
            "output": 512
          }
        }
      }
    }
  },
  "instructions": ["AGENTS.opencode.md"],
  "tool_output": {
    "max_lines": 120,
    "max_bytes": 8000
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 2,
    "preserve_recent_tokens": 1500,
    "reserved": 3000
  },
  "agent": {
    "forensic-examiner": {
      "description": "User-facing forensic examiner for scoped host, filesystem, and image investigations with Markdown reporting.",
      "mode": "primary",
      "prompt": "{file:docs/opencode-agents/forensic-examiner.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "forensic-senior-tooling-specialist": "allow",
          "forensic-evidence-collector": "allow",
          "forensic-artifact-router": "allow",
          "forensic-timeline-analyst": "allow",
          "forensic-report-challenger": "allow",
          "forensic-publication-redactor": "allow",
          "forensic-script-author": "allow",
          "forensic-script-reviewer": "allow",
          "forensic-toolsmith": "allow",
          "forensic-peer-reviewer": "allow",
          "forensic-maintainer": "allow"
        },
        "bash": {
          "*": "ask",
          "date*": "allow",
          "pwd": "allow",
          "pwd *": "allow",
          "ls -d reports artifacts acquisitions 2>/dev/null": "allow",
          "ls -d reports artifacts acquisitions*": "allow",
          "ls -d reports*": "allow",
          "ls -d artifacts*": "allow",
          "ls -d acquisitions*": "allow",
          "test -d reports*": "allow",
          "mkdir -p reports*": "allow",
          "mkdir -p artifacts*": "allow",
          "mkdir -p acquisitions*": "allow",
          "Get-Date*": "allow",
          "Get-TimeZone*": "allow",
          "hostname*": "allow",
          "whoami*": "allow",
          "quser*": "allow",
          "Get-CimInstance Win32_*": "allow",
          "Get-ComputerInfo*": "allow",
          "Get-Process*": "allow",
          "Get-Service*": "allow",
          "Get-ScheduledTask*": "allow",
          "Get-LocalUser*": "allow",
          "Get-LocalGroupMember*": "allow",
          "Get-ChildItem *": "allow",
          "Get-Item *": "allow",
          "Get-ItemProperty *": "allow",
          "Get-FileHash *": "allow",
          "Get-WinEvent*": "allow",
          "wevtutil *": "allow",
          "Where-Object*": "allow",
          "Select-Object*": "allow",
          "Sort-Object*": "allow",
          "Measure-Object*": "allow",
          "Group-Object*": "allow",
          "Format-Table*": "allow",
          "Format-List*": "allow",
          "Out-String*": "allow",
          "Test-Path *": "allow",
          "New-Item -ItemType Directory -Force -Path \"reports*": "allow",
          "New-Item -ItemType Directory -Force -Path reports*": "allow",
          "New-Item -ItemType Directory -Force -Path \"cases*": "allow",
          "New-Item -ItemType Directory -Force -Path cases*": "allow",
          "New-Item -ItemType Directory -Force -Path \"artifacts*": "allow",
          "New-Item -ItemType Directory -Force -Path artifacts*": "allow",
          "New-Item -ItemType Directory -Force -Path \"acquisitions*": "allow",
          "New-Item -ItemType Directory -Force -Path acquisitions*": "allow",
          "Copy-Item *": "allow",
          "Compress-Archive *": "allow",
          "powershell.exe -NoProfile -Command *Where-Object {*": "deny",
          "powershell.exe -NoProfile -Command *ForEach-Object {*": "deny",
          "powershell.exe -NoProfile -Command *+.*": "deny",
          "powershell.exe -NoProfile -Command *IncludeUserName*": "deny",
          "powershell.exe -NoProfile -Command *": "allow",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *Where-Object {*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *ForEach-Object {*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *+.*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *IncludeUserName*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *": "allow",
          "Out-Null*": "allow"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "forensic-senior-tooling-specialist": {
      "description": "Internal senior forensic tooling strategist that coordinates current tool research, provisioning, and execution-flow handoff.",
      "mode": "subagent",
      "steps": 6,
      "prompt": "{file:docs/opencode-agents/forensic-senior-tooling-specialist.md}",
      "permission": {
        "read": "deny",
        "list": "deny",
        "glob": "deny",
        "grep": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "task": {
          "*": "deny",
          "forensic-tool-researcher": "allow",
          "forensic-tool-provisioner": "allow",
          "forensic-script-author": "allow",
          "forensic-script-reviewer": "allow",
          "forensic-maintainer": "allow"
        },
        "bash": "deny",
        "edit": "deny",
        "write": "deny"
      }
    },
    "forensic-tool-researcher": {
      "description": "Internal research-only subagent for current DFIR tool candidates, upstream repositories, official docs, releases, and caveats.",
      "mode": "subagent",
      "steps": 3,
      "prompt": "{file:docs/opencode-agents/forensic-tool-researcher.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": "deny",
        "edit": "deny",
        "write": "deny"
      }
    },
    "forensic-tool-provisioner": {
      "description": "Internal provisioning subagent for staging selected forensic tools, verifying versions or hashes, and preparing bounded execution flows.",
      "mode": "subagent",
      "steps": 4,
      "prompt": "{file:docs/opencode-agents/forensic-tool-provisioner.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "deny",
        "todowrite": "deny",
        "task": {
          "*": "deny",
          "forensic-maintainer": "allow"
        },
        "bash": {
          "*": "ask",
          "Get-Date*": "allow",
          "Get-TimeZone*": "allow",
          "Get-Command *": "allow",
          "Test-Path *": "allow",
          "Get-ChildItem *": "allow",
          "New-Item *": "ask",
          "Get-FileHash *": "allow",
          "git --version*": "allow",
          "git clone *": "ask",
          "git fetch *": "ask",
          "git pull *": "ask",
          "Invoke-WebRequest *": "ask",
          "curl *": "ask",
          "tar *": "ask",
          "Expand-Archive *": "ask"
        },
        "edit": "ask",
        "write": "ask"
      }
    },
    "forensic-evidence-collector": {
      "description": "Internal collection subagent that executes approved scoped collection flows, writes evidence/status outputs, records hashes and blockers, and avoids analysis.",
      "mode": "subagent",
      "steps": 8,
      "prompt": "{file:docs/opencode-agents/forensic-evidence-collector.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": {
          "*": "ask",
          "date*": "allow",
          "pwd": "allow",
          "mkdir -p reports*": "allow",
          "mkdir -p artifacts*": "allow",
          "mkdir -p acquisitions*": "allow",
          "Get-Date*": "allow",
          "Get-TimeZone*": "allow",
          "Get-FileHash *": "allow",
          "powershell.exe -NoProfile -Command *Where-Object {*": "deny",
          "powershell.exe -NoProfile -Command *ForEach-Object {*": "deny",
          "powershell.exe -NoProfile -Command *+.*": "deny",
          "powershell.exe -NoProfile -Command *IncludeUserName*": "deny",
          "powershell.exe -NoProfile -Command *Now.AddHours*": "deny",
          "powershell.exe -NoProfile -Command *&&*": "deny",
          "powershell.exe -NoProfile -Command *": "allow",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *Where-Object {*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *ForEach-Object {*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *+.*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *IncludeUserName*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *Now.AddHours*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *&&*": "deny",
          "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command *": "allow"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "forensic-artifact-router": {
      "description": "Internal routing subagent that maps collected artifacts to parser lanes, specialist analysis paths, controlled sensitive-store handling, and timeline inputs.",
      "mode": "subagent",
      "steps": 4,
      "prompt": "{file:docs/opencode-agents/forensic-artifact-router.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": "deny",
        "edit": "deny",
        "write": "deny"
      }
    },
    "forensic-timeline-analyst": {
      "description": "Internal timeline-analysis subagent that correlates collected artifacts into a normalized user and system activity timeline.",
      "mode": "subagent",
      "steps": 6,
      "prompt": "{file:docs/opencode-agents/forensic-timeline-analyst.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": "deny",
        "edit": "allow",
        "write": "allow"
      }
    },
    "forensic-report-challenger": {
      "description": "Internal adversarial report reviewer for unsupported claims, attribution weakness, alternative explanations, and release-blocking gaps.",
      "mode": "subagent",
      "steps": 4,
      "prompt": "{file:docs/opencode-agents/forensic-report-challenger.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": "deny",
        "edit": "deny",
        "write": "deny"
      }
    },
    "forensic-publication-redactor": {
      "description": "Internal publication-redaction reviewer for repo, report, export, and commit hygiene before sharing or pushing.",
      "mode": "subagent",
      "steps": 5,
      "prompt": "{file:docs/opencode-agents/forensic-publication-redactor.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git grep *": "allow",
          "git log *": "allow",
          "git ls-files*": "allow",
          "git rev-parse *": "allow",
          "rg *": "allow",
          "python scripts/validate_repo_hygiene.py*": "allow"
        },
        "edit": "deny",
        "write": "deny"
      }
    },
    "forensic-script-author": {
      "description": "Internal offline/no-download fallback subagent that generates small read-only forensic scripts using installed runtimes and native APIs.",
      "mode": "subagent",
      "steps": 6,
      "prompt": "{file:docs/opencode-agents/forensic-script-author.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": {
          "*": "ask",
          "python --version*": "allow",
          "python3 --version*": "allow",
          "pwsh --version*": "allow",
          "powershell.exe -NoProfile -Command *$PSVersionTable*": "allow",
          "Get-Command *": "allow"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "forensic-script-reviewer": {
      "description": "Internal generated-script validation subagent for static review, syntax checks, dry-run or fixture tests, logging, and approval before use.",
      "mode": "subagent",
      "steps": 6,
      "prompt": "{file:docs/opencode-agents/forensic-script-reviewer.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": {
          "*": "ask",
          "python -m py_compile *": "allow",
          "python3 -m py_compile *": "allow",
          "bash -n *": "allow",
          "pwsh -NoProfile -Command *": "ask",
          "powershell.exe -NoProfile -Command *": "ask",
          "Get-FileHash *": "allow"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "forensic-toolsmith": {
      "description": "Legacy compatibility helper that delegates substantive tool research and provisioning to the senior tooling specialist.",
      "mode": "subagent",
      "prompt": "{file:docs/opencode-agents/forensic-toolsmith.md}",
      "permission": {
