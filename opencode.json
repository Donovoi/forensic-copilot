{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "default_agent": "forensic-examiner",
  "disabled_providers": ["gemini", "google", "ollama"],
  "instructions": [
    "AGENTS.md",
    ".github/agents/*.agent.md",
    "docs/limitations.md",
    "docs/tooling-matrix.md",
    "docs/peer-review-process.md",
    "docs/privacy-and-redaction.md"
  ],
  "agent": {
    "forensic-examiner": {
      "description": "User-facing forensic examiner for scoped host, filesystem, and image investigations with Markdown reporting.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-examiner.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "forensic-senior-tooling-specialist": "allow",
          "forensic-toolsmith": "allow",
          "forensic-peer-reviewer": "allow",
          "forensic-maintainer": "allow"
        },
        "bash": {
          "*": "ask",
          "Get-Date*": "allow",
          "Get-TimeZone*": "allow",
          "hostname*": "allow",
          "whoami*": "allow",
          "quser*": "allow",
          "Get-CimInstance Win32_*": "allow",
          "Get-ComputerInfo*": "allow",
          "Get-Process*": "allow",
          "Get-Service*": "allow",
          "Get-ScheduledTask*": "allow",
          "Get-LocalUser*": "allow",
          "Get-LocalGroupMember*": "allow",
          "Get-ChildItem *": "allow",
          "Get-Item *": "allow",
          "Get-ItemProperty *": "allow",
          "Get-FileHash *": "allow",
          "Get-WinEvent*": "allow",
          "wevtutil *": "allow",
          "Where-Object*": "allow",
          "Select-Object*": "allow",
          "Sort-Object*": "allow",
          "Measure-Object*": "allow",
          "Group-Object*": "allow",
          "Format-Table*": "allow",
          "Format-List*": "allow",
          "Out-String*": "allow",
          "Test-Path *": "allow",
          "New-Item -ItemType Directory -Force -Path \"reports*": "allow",
          "New-Item -ItemType Directory -Force -Path reports*": "allow",
          "New-Item -ItemType Directory -Force -Path \"cases*": "allow",
          "New-Item -ItemType Directory -Force -Path cases*": "allow",
          "New-Item -ItemType Directory -Force -Path \"artifacts*": "allow",
          "New-Item -ItemType Directory -Force -Path artifacts*": "allow",
          "New-Item -ItemType Directory -Force -Path \"acquisitions*": "allow",
          "New-Item -ItemType Directory -Force -Path acquisitions*": "allow",
          "Copy-Item *": "allow",
          "Compress-Archive *": "allow",
          "Out-Null*": "allow"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "forensic-senior-tooling-specialist": {
      "description": "Internal senior forensic tooling strategist that coordinates current tool research, provisioning, and execution-flow handoff.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-senior-tooling-specialist.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "forensic-tool-researcher": "allow",
          "forensic-tool-provisioner": "allow",
          "forensic-maintainer": "allow"
        },
        "bash": {
          "*": "ask",
          "Get-Date*": "allow",
          "Get-TimeZone*": "allow",
          "hostname*": "allow",
          "whoami*": "allow",
          "quser*": "allow",
          "Get-Command *": "allow",
          "Test-Path *": "allow",
          "Get-ChildItem *": "allow",
          "Get-CimInstance Win32_*": "allow",
          "Get-ComputerInfo*": "allow",
          "Get-Process*": "allow"
        },
        "edit": "ask",
        "write": "ask"
      }
    },
    "forensic-tool-researcher": {
      "description": "Internal research-only subagent for current DFIR tool candidates, upstream repositories, official docs, releases, and caveats.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-tool-researcher.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": "deny",
        "bash": "deny",
        "edit": "deny",
        "write": "deny"
      }
    },
    "forensic-tool-provisioner": {
      "description": "Internal provisioning subagent for staging selected forensic tools, verifying versions or hashes, and preparing bounded execution flows.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-tool-provisioner.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "forensic-maintainer": "allow"
        },
        "bash": {
          "*": "ask",
          "Get-Date*": "allow",
          "Get-TimeZone*": "allow",
          "Get-Command *": "allow",
          "Test-Path *": "allow",
          "Get-ChildItem *": "allow",
          "New-Item *": "ask",
          "Get-FileHash *": "allow",
          "git --version*": "allow",
          "git clone *": "ask",
          "git fetch *": "ask",
          "git pull *": "ask",
          "Invoke-WebRequest *": "ask",
          "curl *": "ask",
          "tar *": "ask",
          "Expand-Archive *": "ask"
        },
        "edit": "ask",
        "write": "ask"
      }
    },
    "forensic-toolsmith": {
      "description": "Legacy compatibility helper that delegates substantive tool research and provisioning to the senior tooling specialist.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-toolsmith.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "forensic-senior-tooling-specialist": "allow",
          "forensic-maintainer": "allow"
        },
        "bash": "deny",
        "edit": "deny",
        "write": "deny"
      }
    },
    "forensic-peer-reviewer": {
      "description": "Internal second-reader for challenging forensic reports, inference strength, corroboration, and release readiness.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-peer-reviewer.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": "deny",
        "bash": "deny",
        "edit": "deny",
        "write": "deny"
      }
    },
    "forensic-maintainer": {
      "description": "Internal maintainer for narrow, justified workflow updates after real investigations or tooling friction.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:.github/agents/forensic-maintainer.agent.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "task": "deny",
        "bash": "ask",
        "edit": "ask",
        "write": "ask"
      }
    }
  }
}
